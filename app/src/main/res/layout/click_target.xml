<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="64dp"
    android:layout_height="64dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/target_crosshair"
        android:contentDescription="Click target" />

    <TextView
        android:id="@+id/tv_target_number"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="1"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/target_number_bg" />

    <ImageButton
        android:id="@+id/btn_remove_target"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:src="@drawable/ic_close"
        android:background="@drawable/circle_button_red"
        android:scaleType="centerInside"
        android:contentDescription="Remove target"
        android:padding="4dp" />

</FrameLayout>
