<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_background"
    android:padding="4dp"
    android:elevation="8dp">

    <!-- Toggle / Drag Handle -->
    <ImageButton
        android:id="@+id/btn_toggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_expand"
        android:background="@drawable/circle_button"
        android:scaleType="centerInside"
        android:contentDescription="Toggle panel"
        android:padding="12dp"
        android:layout_gravity="center_horizontal" />

    <!-- Expanded Panel -->
    <LinearLayout
        android:id="@+id/expanded_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Click counter -->
        <TextView
            android:id="@+id/tv_click_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 clicks"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- Controls row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/circle_button_green"
                android:scaleType="centerInside"
                android:contentDescription="Play"
                android:padding="10dp"
                android:layout_margin="4dp" />

            <ImageButton
                android:id="@+id/btn_pause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_pause"
                android:background="@drawable/circle_button"
                android:scaleType="centerInside"
                android:contentDescription="Pause"
                android:padding="10dp"
                android:layout_margin="4dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_stop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_stop"
                android:background="@drawable/circle_button_red"
                android:scaleType="centerInside"
                android:contentDescription="Stop"
                android:padding="10dp"
                android:layout_margin="4dp" />

            <ImageButton
                android:id="@+id/btn_add_target"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_add_target"
                android:background="@drawable/circle_button"
                android:scaleType="centerInside"
                android:contentDescription="Add target"
                android:padding="10dp"
                android:layout_margin="4dp" />

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/circle_button"
                android:scaleType="centerInside"
                android:contentDescription="Close"
                android:padding="10dp"
                android:layout_margin="4dp" />

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
