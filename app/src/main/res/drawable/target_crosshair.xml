<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer circle -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#FF5722" />
            <solid android:color="#22FF5722" />
        </shape>
    </item>
    <!-- Horizontal line -->
    <item
        android:top="30dp"
        android:bottom="30dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
        </shape>
    </item>
    <!-- Vertical line -->
    <item
        android:top="0dp"
        android:bottom="0dp"
        android:left="30dp"
        android:right="30dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF5722" />
        </shape>
    </item>
</layer-list>
